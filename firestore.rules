rules_version = '2';

// Firestore security rules — shared between THREE apps in project kres-portfolio:
//
//   1) Kres portfolio (existing app):
//      - users, usernames, portfolio, analytics, viewers, settings, messages
//
//   2) progtype site (this repo, static site on GitHub Pages):
//      - articles/{slug}        -> articles (with creatorId field)
//      - article_views/{id}     -> view events for analytics
//      - creators/{uid}         -> creator profiles (created by Telegram bot)
//
//   3) progtype Telegram bot (separate Python service on HuggingFace Spaces):
//      - Uses Firebase Admin SDK (bypasses rules — full access)
//      - Creates /creators/{uid} + Firebase Auth users
//      - Reads /articles, /article_views for analytics

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // progtype super-admin — determined by Firebase Auth email.
    // This email is configured in src/lib/firebase.ts as ADMIN_EMAIL.
    function isProgtypeAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'kres@krestype.app';
    }

    // progtype creator — signed-in user with active profile in /creators.
    function isProgtypeCreator() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/creators/$(request.auth.uid))
        && get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.active == true;
    }

    // ============ PROGTYPE (this app) ============

    // Creator profiles — created by Telegram bot (Admin SDK, bypasses rules).
    // Creator can read own profile. Admin can read all.
    match /creators/{uid} {
      allow read: if isProgtypeAdmin()
        || (isSignedIn() && request.auth.uid == uid);
      // No client writes — only Admin SDK (bot) writes here.
      allow write: if false;
    }

    // Articles: public read. Write: only owner (creatorId == uid) or super-admin.
    match /articles/{slug} {
      allow read: if true;
      // Create: must set creatorId == own uid (or be super-admin).
      allow create: if isProgtypeAdmin()
        || (isProgtypeCreator()
            && request.resource.data.creatorId == request.auth.uid);
      // Update/Delete: existing article's creatorId must match uid, or be super-admin.
      allow update, delete: if isProgtypeAdmin()
        || (isProgtypeCreator()
            && resource.data.creatorId == request.auth.uid);
    }

    // Article view events for analytics.
    match /article_views/{id} {
      allow read: if isProgtypeAdmin();
      allow create: if request.resource.data.slug is string
        && request.resource.data.title is string
        && request.resource.data.timestamp is number
        && request.resource.data.dayKey is string;
      allow update, delete: if isProgtypeAdmin();
    }

    // ============ KRES PORTFOLIO (existing app) ============

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && (
          (request.auth.uid == uid
           && request.resource.data.isAdmin == false
           && (request.resource.data.status is string
               ? request.resource.data.status == 'pending'
               : true))
          || (isAdmin()
           && request.resource.data.isAdmin == false
           && request.resource.data.status == 'approved')
        );
      allow update: if isAdmin();
      allow delete: if isAdmin();
      match /logins/{id} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow update, delete: if isAdmin();
      }
    }

    match /usernames/{name} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /portfolio/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/portfolio {
      allow read: if isAdmin();
      allow update: if isSignedIn();
      allow create: if isSignedIn();
    }
    match /viewers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /messages/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      allow delete: if isSignedIn();
      allow update: if false;
    }
  }
}
