rules_version = '2';

// krestype security rules
// - Чтение статей: публичное (для всех)
// - Запись: только аутентифицированным пользователям (админ)
//   Публичная регистрация отключена, поэтому только вручную созданный
//   пользователь kres@krestype.app может войти и писать.
service cloud.firestore {
  match /databases/{database}/documents {
    // Статьи
    match /articles/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Запретить всё остальное
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
